# Relayer service environment variables
# Copy to .env and fill in

# Port to listen on
PORT=3002

# Starknet RPC endpoint
STARKNET_RPC_URL=https://starknet-sepolia.g.alchemy.com/starknet/version/rpc/v0_10/cCOvFD0gs7yy-YBEph_J5

# Relayer account address (pays gas fees)
RELAYER_ADDRESS=0x...

# Relayer private key (hex, no 0x prefix needed)
RELAYER_PRIVATE_KEY=...

# SatKey account class hash (deployed on-chain)
SATKEY_CLASS_HASH=0x...

# Verifier contract address (deployed on-chain)
VERIFIER_ADDRESS=0x...

# Optional: chain id override (default: SN_SEPOLIA)
VERIFIER_ADDRESS=0x...
# Optional: chain id override (default: SN_SEPOLIA)
# STARKNET_CHAIN_ID=SN_SEPOLIA
