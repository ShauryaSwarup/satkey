{
  "name": "@satkey/prover",
  "version": "0.1.0",
  "description": "ZK prover service — generates Noir/Barretenberg proofs for Sat Key BTC auth",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "starknet": "^9.2.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm lint",
      "pnpm typecheck"
    ]
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
