# SatKey Prover — Copy to .env

PORT=3001                                    # Service port

# Starknet contracts
NEXT_PUBLIC_SATKEY_CLASS_HASH=0x...           # Deployed SatKeyAccount class hash
VERIFIER_CLASS_HASH=0x...                    # Garaga verifier class hash (for library_call)
NEXT_PUBLIC_VERIFIER_CLASS_HASH=0x...          # Garaga verifier class hash (for library_call)

# Circuit paths
CIRCUIT_ARTIFACT_PATH=../../circuits/satkey_auth/target/satkey_auth.json
WORK_DIR=/tmp/satkey_prover                  # Temp directory for proof generation

# Binary paths
BB_BIN=bb                                    # Barretenberg binary
NARGO_BIN=nargo                              # Noir CLI binary
