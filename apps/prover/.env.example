# Prover service environment variables
# Copy to .env and fill in

# Port to listen on
PORT=3001

# Class hash of the deployed SatKey contract on Starknet
SATKEY_CLASS_HASH=0x

# Address of the deployed Verifier contract on Starknet
VERIFIER_ADDRESS=0x

# Path to the compiled Noir circuit artifact (satkey_auth.json)
CIRCUIT_ARTIFACT_PATH=../../circuits/satkey_auth/target/satkey_auth.json

# Path to the proving key (generated by `bb write_pk`)
PROVING_KEY_PATH=../../circuits/satkey_auth/target/pk.bin

# Working directory for temporary Prover.toml / proof files
WORK_DIR=/tmp/satkey_prover

# Path to the `bb` (Barretenberg) binary
BB_BIN=bb

# Path to the `nargo` binary
NARGO_BIN=nargo
